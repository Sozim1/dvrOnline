FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
HLS_SEGMENT_SECONDS=1
HLS_LIST_SIZE=4
HLS_STALE_SECONDS=15
HLS_START_TIMEOUT_SECONDS=25
HLS_RTSP_TIMEOUT_MICROSECONDS=0
HLS_TRANSCODE=false

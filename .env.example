NODE_ENV=production
TZ=America/Sao_Paulo
HOST=0.0.0.0
PORT=4000
BACKEND_BIND=127.0.0.1
BACKEND_PORT=4000
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_API_URL=
PUBLIC_WEBRTC_URL=
WEBRTC_HTTP_BIND=0.0.0.0
WEBRTC_HTTP_PORT=8889
WEBRTC_ADDITIONAL_HOSTS=IP_DO_SERVIDOR
WEBRTC_UDP_PORT=8189

JWT_SECRET=troque-este-segredo-por-um-valor-grande
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=troque-esta-senha

CAMERA_NAME=Camera Sala
RTSP_MAIN=rtsp://admin:CODIGO@192.168.0.50:554/ch1/main
RTSP_SUB=rtsp://admin:CODIGO@192.168.0.50:554/ch1/sub
DEFAULT_STREAM=main
RECORDING_STREAM=main
MOTION_STREAM=sub

DATABASE_PATH=./storage/data/nvr.sqlite
RECORDINGS_PATH=./storage/recordings
BACKUP_PATH=./storage/backups
HLS_PATH=./storage/hls
SNAPSHOTS_PATH=./storage/snapshots

AUTO_RECORDING_ENABLED=true
SEGMENT_SECONDS=300
RETENTION_DAYS=7
MOTION_ENABLED=false
